<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!-- LAN 内の別マシンで動かしているサーバーに繋ぐときは Server.Host を書き換える。
         例: <add key="Server.Host" value="192.168.1.10" /> -->
    <add key="Server.Host" value="localhost" />
    <add key="Server.Port" value="5000" />
  </appSettings>
</configuration>
